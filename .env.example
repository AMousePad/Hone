# Hone E2E test configuration.

# URL the Playwright browser navigates to.
LUMIVERSE_URL=http://localhost:7860

# Filesystem root of Lumiverse data dir (holds users/<uuid>/extensions/hone/settings.json).
LUMIVERSE_DATA_DIR=

# Operator accounts. Playwright worker N uses LUMIVERSE_ACCOUNT_N_*.
# USER_ID is the UUID under $LUMIVERSE_DATA_DIR/users/ for this account.
LUMIVERSE_ACCOUNT_0_USERNAME=
LUMIVERSE_ACCOUNT_0_PASSWORD=
LUMIVERSE_ACCOUNT_0_USER_ID=

# Additional Accounts
# LUMIVERSE_ACCOUNT_1_USERNAME=
# LUMIVERSE_ACCOUNT_1_PASSWORD=
# LUMIVERSE_ACCOUNT_1_USER_ID=

# Set to 1 to run @llm suites
# RUN_LLM=1
